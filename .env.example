# Ambiente da aplicacao: local, development, staging ou production.
APP_ENV=local
APP_DEBUG=false
APP_NAME="License Insight Scraper API"
API_PREFIX=/api/v1

# Origens CORS separadas por virgula.
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# URLs do portal externo.
SCRAPER_LOGIN_URL=https://balcaovirtual.inatro.gov.mz/app/ajax/auth/login.php
SCRAPER_LICENSE_STATUS_URL=https://balcaovirtual.inatro.gov.mz/estado_carta.php
SCRAPER_DRIVING_TICKET_URL=https://balcaovirtual.inatro.gov.mz/consulta_multas.php

# Resiliencia e rede.
SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_MULTIPLIER=0.8
SCRAPER_PROXY_URL=
SCRAPER_VERIFY_SSL=true

# Logs: DEBUG, INFO, WARNING ou ERROR.
LOG_LEVEL=INFO
